[global/wm]
margin-top = 32
margin-bottom = 22

[colors]

primary = #000C66
secondary = #e60053
alert = #bd2c40

background = #050A30
foreground = #7EC8E3
underline = #0000FF

[bar/the_one_bar]
;monitor = ${env:MONITOR}
bottom = false
border-size = 1
width = 100%
height = 25
radius = 5.0
fixed-center = true

padding-left = 2
padding-right = 4
module-margin-left = 1
module-margin-right = 2

background = ${colors.background}
line-color = #f00
border-color = #00000000

locale = en_US.UTF-8
font-0 = Ubuntu:style=Regular
font-1 = "Font Awesome 6 Free:style=Regular:size=12;0"
font-2 = "Font Awesome 6 Free:style=Solid:size=12;0"
font-3 = "Font Awesome 6 Brands:style=Regular:size=12;0"
modules-left = cpu memory network backlight ewmh
modules-center = date
modules-right = volume microphone battery uptime power_off

line-size = 3
tray-position = right
tray-padding = 1
tray-transparent = true
wm-restack = i3

[module/ewmh]
type = internal/xworkspaces

; Only show workspaces defined on the same output as the bar
;
; Useful if you want to show monitor specific workspaces
; on different bars
;
; Default: false
pin-workspaces = false

; Create click handler used to focus desktop
; Default: true
enable-click = true

; Create scroll handlers used to cycle desktops
; Default: true
enable-scroll = false

; Reverse the scroll direction
; Default: false
; New in version 3.6.0
reverse-scroll = true


[module/microphone]
type = custom/script
exec = ~/.config/polybar/polybar-scripts/pulseaudio-microphone.sh
tail = true
click-left = ~/.config/polybar/polybar-scripts/pulseaudio-microphone.sh --toggle &
scroll-up = ~/.config/polybar/polybar-scripts/pulseaudio-microphone.sh --increase &
scroll-down = ~/.config/polybar/polybar-scripts/pulseaudio-microphone.sh --decrease &

[module/network]
type = internal/network
interface = wlp2s0
interval = 3.0

unknown-as-up = true

format-connected = <label-connected>
format-prefix = 
format-disconnected = <label-disconnected>

format-packetloss = <animation-packetloss> <label-packetloss>

label-connected = %downspeed:9%

label-disconnected = No Internet
label-disconnected-foreground = #66ffffff

label-packetloss = %essid%
label-packetloss-foreground = #eefafafa

animation-packetloss-0 = ⚠
animation-packetloss-0-foreground = #ffa64c
animation-packetloss-1 = 📶
animation-packetloss-1-foreground = #000000
; Framerate in milliseconds
animation-packetloss-framerate = 500

[module/power_off]
type = custom/text
content =  Ubuntu

[module/date]
type = internal/date
interval = 1.0

date = %Y-%m-%d%

; Optional time format
time = %H:%M

[module/battery]
;https://config.phundrak.com/Deprecated/polybar.html is used
type = internal/battery
full-at = 99

; $ ls -1 /sys/class/power_supply/
battery = BAT0
adapter = ADP1

poll-interval = 5

format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>

label-charging = %percentage%%
label-discharging = %percentage%%
label-full = %percentage%%

; Only applies if <ramp-capacity> is used
ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

; Only applies if <bar-capacity> is used
bar-capacity-width = 10

; Only applies if <animation-charging> is used
animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
; Framerate in milliseconds
animation-charging-framerate = 750

[module/backlight]
type = internal/backlight
label = %percentage%%
format-prefix = " "
format-underline = #ffffff
format-padding = 2
format-background = ${colors.primary}
card = amdgpu_bl0
enable-scroll = true

[module/cpu]
type = internal/cpu
interval = 3
label = %percentage%%
format-prefix = " "
format-underline = #f90000
format-padding = 2
format-background = ${colors.primary}

[module/memory]
type = internal/memory
interval = 3
label = %percentage_used%%
format-prefix = " "
format-underline = #f90000
format-padding = 2
format-background = ${colors.primary}

[module/volume]
type = internal/pulseaudio
sink = alsa_output.pci-0000_12_00.3.analog-stereo

use-ui-max = true
format-volume = <ramp-volume> <label-volume>
format-muted = <label-muted>

label-volume = %percentage%%
label-muted =  %percentage%%
label-muted-foreground = #666

; Only applies if <ramp-volume> is used
ramp-volume-0 = 
ramp-volume-1 = 

[module/uptime]
type = custom/script
exec = $HOME/.config/polybar/polybar-scripts/system-uptime-pretty.sh
interval = 30
